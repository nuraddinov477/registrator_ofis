# ── Backend muhit o'zgaruvchilari ──
# Lokal (SQLite):
DATABASE_URL="file:./dev.db"
# Production (PostgreSQL):
# DATABASE_URL="postgresql://user:parol@host:5432/unischedule?schema=public"

PORT=4000
NODE_ENV=development
# Frontend manzili (vergul bilan bir nechta): https://app.example.uz
CLIENT_ORIGIN="http://localhost:5173"

# JWT — production'da MAJBURIY va kuchli bo'lsin (masalan: openssl rand -hex 32)
JWT_SECRET="dev-secret-change-me"
JWT_EXPIRES_IN="7d"

# Ixtiyoriy
RATE_LIMIT_MAX=300
RATE_LIMIT_AUTH_MAX=20
BODY_LIMIT=1mb

# AI yordamchi — Claude (asosiy) yoki Gemini (bepul test rejimi) ANTHROPIC_API_KEY bo'lsa Claude ustunlik qiladi
# ANTHROPIC_API_KEY="sk-ant-..."
# GEMINI_API_KEY="AIza..."
